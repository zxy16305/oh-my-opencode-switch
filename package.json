{
  "name": "oos-cli",
  "version": "0.1.0",
  "description": "oh-my-opencode switch - Configuration profile manager",
  "main": "./bin/oos.js",
  "type": "module",
  "bin": {
    "oos": "./bin/oos.js"
  },
  "scripts": {
    "test": "node --no-warnings --test tests/**/*.test.js",
    "test:unit": "node --no-warnings --test tests/unit/**/*.test.js",
    "test:integration": "node --no-warnings --test tests/integration/**/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "cli",
    "config",
    "opencode",
    "profile"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "atomically": "^2.0.3",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "handlebars": "^4.7.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.8.1"
  }
}
