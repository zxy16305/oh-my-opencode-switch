{
  "$schema": "https://raw.githubusercontent.com/zxy16305/oh-my-opencode-switch/master/schemas/proxy-config.schema.json",
  "port": 3000,
  "auth": {
    "enabled": false,
    "keys": [
      { "key": "sk-your-api-key-1", "name": "dev-key", "enabled": true },
      { "key": "sk-your-api-key-2", "name": "prod-key", "enabled": false }
    ]
  },
  "reliability": {
    "allowedFails": 2,
    "cooldownTimeMs": 60000
  },
  "routes": {
    "lb-qwen-plus": {
      "strategy": "sticky",
      "upstreams": [
        { "provider": "ali", "model": "qwen-plus" },
        { "provider": "ali", "model": "qwen-plus" }
      ]
    },
    "lb-mixed": {
      "strategy": "round-robin",
      "upstreams": [
        { "provider": "ali", "model": "glm-4.7" },
        { "provider": "baidu", "model": "qianfan-code-latest" }
      ]
    }
  }
}
